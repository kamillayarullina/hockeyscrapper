# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here

# Deployment
DEPLOY_URL=https://your-deployment.example.com

# JWT secret (change to a random string in production)
JWT_SECRET_KEY=change-this-to-a-random-string-in-production

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*

# Email (password recovery) — app password for Gmail SMTP
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# Database
DATABASE_URL=sqlite:///data/tickets.db
