# Telegram
BOT_TOKEN=your_token_here
ADMIN_CHAT_ID=your_chat_id_here

# Email (Gmail SMTP)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_LOGIN=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_TO=your_email@gmail.com

# Billing (YooKassa)
# Use test-shop credentials first. Never commit real keys.
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# Public HTTPS address of this app; used after checkout and in YooKassa webhook setup.
APP_BASE_URL=http://localhost:8000
# Local-only simulation. Keep false or omit this variable on a real server.
BILLING_DEMO_MODE=false
