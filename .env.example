# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here

# Mail (Yandex app password) — для восстановления пароля
MAIL_USERNAME=your_yandex_email
MAIL_PASSWORD=your_yandex_app_password
MAIL_PORT=587
MAIL_SERVER=smtp.yandex.ru
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# JWT (подпись токенов) — смените на своё значение в production!
JWT_SECRET_KEY=hockeyscrapper-secret-change-in-production

# База данных (по умолчанию SQLite)
DATABASE_URL=sqlite:///data/tickets.db
DB_PATH=data/tickets.db

# Deployment
DEPLOY_URL=https://your-deployment.example.com
PORT=8000
