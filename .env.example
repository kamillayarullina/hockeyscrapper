# Telegram
BOT_TOKEN=your_token_here
BOT_USERNAME=your_bot_username
ADMIN_CHAT_ID=your_chat_id_here

# Email (Gmail SMTP) — используется и FastMail (Backend), и EmailSender (парсер)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# JWT
JWT_SECRET_KEY=your-secret-change-in-production

# Database
DATABASE_URL=sqlite:///data/tickets.db

# Server

ADMIN_EMAILS=admin@example.com

# Billing (YooKassa)
# Use test-shop credentials first. Never commit real keys.
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
# Public HTTPS address of this app; used after checkout and in YooKassa webhook setup.
APP_BASE_URL=http://localhost:8000
# Local-only simulation. Keep false or omit this variable on a real server.
BILLING_DEMO_MODE=false
