# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_CHAT_ID=your_chat_id_here

# Deployment
DEPLOY_URL=https://your-deployment.example.com

# Email (password recovery) — app password for Gmail SMTP
